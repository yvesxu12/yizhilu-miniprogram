.page-ai-chat { display:flex; flex-direction:column; height:100vh; background:#F0F2F5; }

/* 角色切换 */
.personality-bar { display:flex; background:#FFF; padding:16rpx 24rpx; gap:16rpx; border-bottom:1rpx solid #F0F0F0; }
.p-item { display:flex; align-items:center; padding:10rpx 24rpx; border-radius:32rpx; background:#F5F7FA; font-size:24rpx; }
.p-item.active { background:#E3F2FD; }
.p-emoji { font-size:28rpx; margin-right:4rpx; }
.p-name { color:#666; }
.p-item.active .p-name { color:#5B9BD5; font-weight:600; }

/* 头部 */
.chat-header { display:flex; align-items:center; padding:24rpx 32rpx; background:#FFF; border-bottom:1rpx solid #F0F0F0; }
.chat-header-emoji { font-size:56rpx; margin-right:16rpx; }
.chat-header-name { font-size:30rpx; font-weight:600; color:#333; display:block; }
.chat-header-desc { font-size:22rpx; color:#999; display:block; margin-top:2rpx; }

/* 安全提示 */
.safety-tip { text-align:center; padding:12rpx 24rpx; background:#FFF8E1; font-size:20rpx; color:#999; }

/* 消息列表 */
.msg-list { flex:1; padding:20rpx 24rpx; overflow-y:auto; }
.msg-item { margin-bottom:24rpx; display:flex; }
.msg-user { justify-content:flex-end; }
.msg-ai { justify-content:flex-start; }

.msg-bubble { max-width:80%; padding:20rpx 24rpx; border-radius:20rpx; position:relative; }
.ai-bubble { background:#FFF; border-top-left-radius:4rpx; }
.user-bubble { background:#5B9BD5; border-top-right-radius:4rpx; }
.user-bubble .bubble-text { color:#FFF; }
.user-bubble .bubble-time { color:rgba(255,255,255,.6); }

.bubble-text { font-size:28rpx; line-height:1.6; white-space:pre-wrap; word-break:break-all; display:block; }
.bubble-time { font-size:20rpx; color:#CCC; margin-top:8rpx; display:block; text-align:right; }

/* 正在输入 */
.typing-bubble { padding:24rpx 32rpx; }
.typing-dots { display:flex; gap:8rpx; }
.dot { width:12rpx; height:12rpx; border-radius:50%; background:#CCC; animation:bounce 1.4s ease-in-out infinite; }
.dot:nth-child(2) { animation-delay:.2s; }
.dot:nth-child(3) { animation-delay:.4s; }
@keyframes bounce { 0%,80%,100% {transform:translateY(0)} 40% {transform:translateY(-16rpx)} }

/* 快速话题 */
.quick-topics { padding:16rpx 24rpx 8rpx; }
.qt-label { font-size:24rpx; color:#999; display:block; margin-bottom:12rpx; }
.qt-tags { display:flex; flex-wrap:wrap; gap:12rpx; }
.qt-tag { padding:12rpx 24rpx; background:#FFF; border-radius:24rpx; font-size:24rpx; color:#5B9BD5; border:1rpx solid #E3F2FD; }

/* 输入栏 */
.input-bar { display:flex; align-items:center; padding:16rpx 24rpx; padding-bottom:calc(16rpx + env(safe-area-inset-bottom)); background:#FFF; border-top:1rpx solid #F0F0F0; gap:12rpx; }
.msg-input { flex:1; height:72rpx; background:#F5F7FA; border-radius:36rpx; padding:0 28rpx; font-size:28rpx; }
.send-btn { width:100rpx; height:72rpx; border-radius:36rpx; background:linear-gradient(135deg,#5B9BD5,#7BB3E0); color:#FFF; font-size:28rpx; font-weight:600; border:none; display:flex; align-items:center; justify-content:center; padding:0; }
.send-btn[disabled] { opacity:.4; }
.msg-bottom-space { height:40rpx; }
