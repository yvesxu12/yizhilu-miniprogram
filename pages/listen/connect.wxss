.page-connect { min-height:100vh; background:linear-gradient(180deg,#E8F5E9,#F5F7FA 40%); display:flex; flex-direction:column; align-items:center; padding:40rpx 24rpx; }
.connect-header { text-align:center; margin-bottom:32rpx; }
.ch-avatar { width:160rpx; height:160rpx; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20rpx; }
.ch-avatar text { font-size:64rpx; color:#FFF; font-weight:700; }
.online-avatar { background:linear-gradient(135deg,#66BB6A,#81C784); box-shadow:0 8rpx 24rpx rgba(102,187,106,.3); }
.offline-avatar { background:#CCC; }
.ch-name { font-size:36rpx; font-weight:700; color:#333; display:block; margin-bottom:8rpx; }
.ch-status { font-size:26rpx; display:block; }
.duration-section { width:100%; max-width:600rpx; padding:28rpx; text-align:center; margin-bottom:24rpx; }
.section-label { font-size:28rpx; font-weight:600; color:#333; display:block; margin-bottom:20rpx; }
.duration-options { display:flex; gap:16rpx; }
.dur-item { flex:1; padding:20rpx 12rpx; border-radius:16rpx; background:#F8F9FA; border:2rpx solid transparent; transition:all .2s; }
.dur-item.active { background:#E8F5E9; border-color:#66BB6A; }
.dur-min { font-size:28rpx; font-weight:600; color:#333; display:block; }
.dur-price { font-size:32rpx; font-weight:700; color:#F5A623; display:block; margin:6rpx 0; }
.dur-tag { font-size:20rpx; color:#66BB6A; }
.connect-area { width:100%; max-width:600rpx; text-align:center; margin-bottom:24rpx; }
.connect-main-btn { width:100%; background:linear-gradient(135deg,#66BB6A,#81C784); color:#FFF; font-size:34rpx; font-weight:600; border-radius:48rpx; padding:28rpx 0; border:none; }
.offline-main-btn { background:linear-gradient(135deg,#BDBDBD,#E0E0E0); }
.btn-emoji { font-size:36rpx; margin-right:8rpx; }
.connecting-status { text-align:center; padding:32rpx 0; }
.pulse-ring { width:160rpx; height:160rpx; border-radius:50%; background:rgba(102,187,106,.15); display:flex; align-items:center; justify-content:center; margin:0 auto 24rpx; animation:pulse-ring 1.5s ease-in-out infinite; }
@keyframes pulse-ring { 0%{transform:scale(1);opacity:1} 100%{transform:scale(1.3);opacity:0} }
.pulse-inner { width:100rpx; height:100rpx; border-radius:50%; background:linear-gradient(135deg,#66BB6A,#81C784); display:flex; align-items:center; justify-content:center; }
.pulse-num { font-size:48rpx; color:#FFF; font-weight:700; }
.connecting-text { font-size:28rpx; color:#333; display:block; margin-bottom:8rpx; }
.connecting-sub { font-size:24rpx; color:#999; display:block; }
.cancel-btn { margin-top:24rpx; font-size:28rpx; color:#999; }
.connect-tips { width:100%; max-width:600rpx; padding:24rpx 28rpx; }
.tips-title { font-size:26rpx; font-weight:600; color:#333; display:block; margin-bottom:12rpx; }
.tips-item { font-size:24rpx; color:#999; display:block; line-height:1.8; }
.call-screen { text-align:center; padding-top:60rpx; }
.call-avatar-wrap { position:relative; margin-bottom:24rpx; }
.call-avatar { width:180rpx; height:180rpx; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto; }
.call-avatar text { font-size:72rpx; color:#FFF; font-weight:700; }
.call-wave { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:240rpx; height:240rpx; border-radius:50%; border:3rpx solid rgba(102,187,106,.2); animation:wave 2s ease-in-out infinite; }
@keyframes wave { 0%,100%{transform:translate(-50%,-50%) scale(1);opacity:.3} 50%{transform:translate(-50%,-50%) scale(1.2);opacity:.1} }
.call-name { font-size:36rpx; font-weight:700; color:#333; display:block; }
.call-status { font-size:26rpx; color:#66BB6A; display:block; margin:8rpx 0 24rpx; }
.call-elapsed { font-size:52rpx; font-weight:300; color:#999; }
.call-tip { margin:32rpx 0; padding:20rpx 32rpx; background:rgba(255,255,255,.8); border-radius:12rpx; font-size:26rpx; color:#666; }
.call-actions { margin-top:40rpx; }
.call-end-btn { width:200rpx; height:100rpx; border-radius:50rpx; background:#F44336; color:#FFF; font-size:28rpx; font-weight:600; border:none; display:flex; align-items:center; justify-content:center; }
