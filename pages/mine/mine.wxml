<view class="page-mine">

  <!-- 个人信息区 -->
  <view class="mine-header">
    <view wx:if="{{!isLogin}}" class="login-area" bindtap="goToLogin">
      <view class="avatar-default">👤</view>
      <text class="login-tip">点击登录，开启成长之旅</text>
    </view>
    <view wx:else class="user-area">
      <view class="avatar-wrap">
        <text class="avatar-letter">{{userInfo.nickName ? userInfo.nickName[0] : '👤'}}</text>
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickName || '用户'}}</text>
        <text class="user-sub">成长路上，与你同行</text>
      </view>
    </view>
  </view>

  <!-- 订单概况 -->
  <view class="stats-row card">
    <view class="stat-item">
      <text class="stat-num">{{orderStats.total}}</text>
      <text class="stat-label">全部订单</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{orderStats.pending}}</text>
      <text class="stat-label">进行中</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{orderStats.completed}}</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section card">
    <view
      class="menu-item"
      wx:for="{{menuItems}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onMenuTap"
    >
      <text class="menu-icon">{{item.icon}}</text>
      <text class="menu-title">{{item.title}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 服务与设置 -->
  <view class="menu-section card">
    <view
      class="menu-item"
      wx:for="{{serviceItems}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onMenuTap"
    >
      <text class="menu-icon">{{item.icon}}</text>
      <text class="menu-title">{{item.title}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 底部版本 -->
  <view class="version-text">
    <text>医职路 v1.0.0</text>
  </view>

</view>
