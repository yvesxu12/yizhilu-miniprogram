.page-mine { min-height: 100vh; background: #F5F7FA; padding-bottom: 120rpx; }
.mine-header { background: linear-gradient(180deg, #5B9BD5 0%, #7BB3E0 40%, #BBDEFB 100%); padding: 60rpx 32rpx 80rpx; }
.login-area { display: flex; align-items: center; }
.avatar-default { width: 120rpx; height: 120rpx; border-radius: 50%; background: rgba(255,255,255,0.3); display: flex; align-items: center; justify-content: center; font-size: 60rpx; margin-right: 24rpx; }
.login-tip { font-size: 30rpx; color: #FFFFFF; font-weight: 500; }
.user-area { display: flex; align-items: center; }
.avatar-wrap { width: 120rpx; height: 120rpx; border-radius: 50%; background: rgba(255,255,255,0.3); display: flex; align-items: center; justify-content: center; margin-right: 24rpx; }
.avatar-letter { font-size: 48rpx; color: #FFF; font-weight: 700; }
.user-name { font-size: 36rpx; color: #FFF; font-weight: 700; display: block; }
.user-sub { font-size: 26rpx; color: rgba(255,255,255,0.8); margin-top: 6rpx; display: block; }
.stats-row { margin: -40rpx 24rpx 24rpx; display: flex; align-items: center; padding: 32rpx 0; }
.stat-item { flex: 1; text-align: center; }
.stat-num { font-size: 40rpx; font-weight: 700; color: #333; display: block; }
.stat-label { font-size: 24rpx; color: #999; margin-top: 6rpx; display: block; }
.stat-divider { width: 2rpx; height: 56rpx; background: #F0F0F0; }
.menu-section { margin: 0 24rpx 24rpx; }
.menu-item { display: flex; align-items: center; padding: 28rpx 0; border-bottom: 1rpx solid #F5F5F5; }
.menu-item:last-child { border-bottom: none; }
.menu-item:active { opacity: 0.6; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; width: 48rpx; text-align: center; }
.menu-title { flex: 1; font-size: 28rpx; color: #333; }
.menu-arrow { font-size: 28rpx; color: #CCC; }
.version-text { text-align: center; padding: 32rpx 0; font-size: 24rpx; color: #CCC; }
