.page-service { min-height: 100vh; background: #F5F7FA; }
.service-tabs {
  display: flex; background: #FFF; padding: 0 24rpx;
  border-bottom: 1rpx solid #F0F0F0; position: sticky; top: 0; z-index: 10;
}
.tab-item {
  flex: 1; text-align: center; padding: 28rpx 0; font-size: 28rpx; color: #666;
  position: relative;
}
.tab-item.active { color: #5B9BD5; font-weight: 600; }
.tab-item.active::after {
  content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 48rpx; height: 6rpx; background: #5B9BD5; border-radius: 3rpx;
}
.service-content { padding: 32rpx; }
.placeholder { text-align: center; padding-top: 200rpx; }
.placeholder-icon { font-size: 80rpx; display: block; margin-bottom: 24rpx; }
.placeholder-text { font-size: 30rpx; color: #999; display: block; margin-bottom: 12rpx; }
.placeholder-sub { font-size: 24rpx; color: #CCC; display: block; }
