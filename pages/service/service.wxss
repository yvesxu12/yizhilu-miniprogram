.page-service { min-height:100vh; background:#F5F7FA; padding-bottom:120rpx; }

/* Tabs */
.service-tabs { display:flex; background:#FFF; padding:0 24rpx; position:sticky; top:0; z-index:10; border-bottom:1rpx solid #F0F0F0; }
.tab-item { flex:1; text-align:center; padding:28rpx 0; font-size:28rpx; color:#666; position:relative; }
.tab-item.active { color:#5B9BD5; font-weight:600; }
.tab-item.active::after { content:''; position:absolute; bottom:0; left:50%; transform:translateX(-50%); width:48rpx; height:6rpx; background:#5B9BD5; border-radius:3rpx; }

/* Filter */
.filter-bar { white-space:nowrap; padding:16rpx 24rpx; background:#FFF; border-bottom:1rpx solid #F5F5F5; display:flex; }
.filter-tag { display:inline-block; padding:10rpx 28rpx; border-radius:32rpx; font-size:24rpx; color:#666; background:#F5F7FA; margin-right:16rpx; }
.filter-tag.active { background:#E3F2FD; color:#5B9BD5; font-weight:600; }

.tab-content { padding:20rpx 24rpx; }

/* Provider card */
.provider-card { padding:0; overflow:hidden; margin-bottom:24rpx; }
.provider-header { display:flex; align-items:center; padding:28rpx 28rpx 16rpx; }
.provider-avatar { width:88rpx; height:88rpx; border-radius:50%; background:linear-gradient(135deg,#5B9BD5,#7BB3E0); display:flex; align-items:center; justify-content:center; margin-right:20rpx; flex-shrink:0; }
.provider-avatar text { font-size:36rpx; color:#FFF; font-weight:600; }
.coach-avatar { background:linear-gradient(135deg,#66BB6A,#81C784); }
.provider-info { flex:1; min-width:0; }
.provider-name-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:6rpx; }
.provider-name { font-size:30rpx; font-weight:600; color:#333; }
.provider-rating { font-size:24rpx; color:#F5A623; }
.provider-title { font-size:24rpx; color:#999; display:block; margin-bottom:8rpx; }
.provider-tags { display:flex; flex-wrap:wrap; }
.tag { display:inline-block; padding:4rpx 16rpx; border-radius:20rpx; font-size:20rpx; margin-right:8rpx; margin-bottom:4rpx; }
.tag-info { background:#E3F2FD; color:#5B9BD5; }
.tag-calm { background:#E8F5E9; color:#66BB6A; }
.tag-warm { background:#FFF3E0; color:#F5A623; }
.provider-arrow { font-size:32rpx; color:#CCC; flex-shrink:0; margin-left:8rpx; }

/* Service list */
.service-list { border-top:1rpx solid #F5F5F5; }
.service-item { display:flex; align-items:center; padding:24rpx 28rpx; border-bottom:1rpx solid #FAFAFA; }
.service-item:last-child { border-bottom:none; }
.service-item:active { background:#FAFAFA; }
.service-info { flex:1; }
.service-name { font-size:28rpx; font-weight:500; color:#333; display:block; margin-bottom:4rpx; }
.service-desc { font-size:22rpx; color:#999; display:block; margin-bottom:4rpx; }
.service-duration { font-size:22rpx; color:#5B9BD5; }
.service-price-action { text-align:right; flex-shrink:0; margin-left:16rpx; }
.service-price { font-size:32rpx; font-weight:700; color:#F5A623; display:block; }
.service-action { font-size:24rpx; color:#5B9BD5; margin-top:4rpx; display:block; border:1rpx solid #5B9BD5; border-radius:24rpx; padding:4rpx 20rpx; }

/* Online bar */
.online-bar { display:flex; align-items:center; padding:20rpx 28rpx; background:linear-gradient(135deg,#E8F5E9,#F1F8E9); border-radius:12rpx; margin-bottom:20rpx; font-size:24rpx; color:#333; }
.online-dot-pulse { width:14rpx; height:14rpx; border-radius:50%; background:#66BB6A; margin-right:12rpx; animation:pulse 1.5s ease-in-out infinite; }
@keyframes pulse { 0%,100% {opacity:1} 50% {opacity:.3} }
.online-hint { color:#999; margin-left:8rpx; font-size:22rpx; }

/* Listener card */
.listener-card { padding:0; overflow:hidden; margin-bottom:24rpx; }
.listener-main { display:flex; align-items:center; padding:28rpx 28rpx 8rpx; }
.listener-avatar-wrap { position:relative; margin-right:20rpx; }
.listener-avatar { width:88rpx; height:88rpx; border-radius:50%; display:flex; align-items:center; justify-content:center; }
.listener-avatar.online { background:linear-gradient(135deg,#66BB6A,#81C784); }
.listener-avatar.offline { background:#E0E0E0; }
.listener-avatar text { font-size:36rpx; color:#FFF; font-weight:600; }
.online-badge { width:20rpx; height:20rpx; border-radius:50%; background:#66BB6A; border:3rpx solid #FFF; position:absolute; bottom:0; right:0; }
.listener-info { flex:1; min-width:0; }
.listener-name-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:6rpx; }
.listener-name { font-size:30rpx; font-weight:600; color:#333; }
.listener-rating { font-size:22rpx; color:#999; }
.listener-title { font-size:24rpx; color:#999; display:block; margin-bottom:8rpx; }
.listener-tags { display:flex; flex-wrap:wrap; }
.listener-status { text-align:right; flex-shrink:0; margin-left:12rpx; }
.status-text { font-size:24rpx; display:block; }
.online-text { color:#66BB6A; }
.offline-text { color:#CCC; }
.status-detail { font-size:20rpx; color:#CCC; margin-top:4rpx; }

/* Listener prices */
.listener-prices { display:flex; padding:0 28rpx 16rpx; gap:12rpx; }
.price-option { flex:1; text-align:center; padding:16rpx 8rpx; background:#F8F9FA; border-radius:12rpx; }
.price-option.recommend { background:#E8F5E9; }
.price-num { font-size:28rpx; font-weight:700; color:#333; display:block; }
.price-dur { font-size:20rpx; color:#999; margin-top:2rpx; display:block; }

/* Connect button */
.connect-btn { width:calc(100% - 56rpx); margin:0 28rpx 24rpx; background:linear-gradient(135deg,#66BB6A,#81C784); color:#FFF; font-size:30rpx; font-weight:600; border-radius:44rpx; padding:20rpx 0; border:none; text-align:center; }
.connect-btn:active { opacity:.85; }
.offline-btn { background:linear-gradient(135deg,#BDBDBD,#E0E0E0); }

/* Youth */
.youth-card { position:relative; padding:28rpx; margin-bottom:24rpx; }
.youth-badge { position:absolute; right:28rpx; top:28rpx; background:linear-gradient(135deg,#F5A623,#FF9800); color:#FFF; font-size:20rpx; padding:6rpx 16rpx; border-radius:16rpx; }
.youth-name { font-size:32rpx; font-weight:700; color:#333; display:block; margin-bottom:8rpx; }
.youth-subtitle { font-size:24rpx; color:#999; display:block; margin-bottom:12rpx; }
.youth-desc { font-size:26rpx; color:#666; line-height:1.6; display:block; margin-bottom:16rpx; }
.youth-weeks { margin-bottom:16rpx; }
.week-item { display:block; font-size:24rpx; color:#666; padding:6rpx 0; padding-left:12rpx; border-left:2rpx solid #5B9BD5; margin-bottom:6rpx; }
.youth-coach-info { display:flex; align-items:center; gap:16rpx; margin-bottom:12rpx; flex-wrap:wrap; font-size:24rpx; }
.youth-coach { color:#333; font-weight:600; }
.youth-coach-title { color:#999; }
.youth-rating { color:#F5A623; }
.youth-tags { display:flex; flex-wrap:wrap; margin-bottom:16rpx; }
.youth-groups { margin-bottom:16rpx; }
.group-item { display:block; font-size:26rpx; color:#333; padding:12rpx 16rpx; background:#F8F9FA; border-radius:8rpx; margin-bottom:8rpx; }
.youth-bottom { display:flex; align-items:center; justify-content:space-between; padding-top:16rpx; border-top:1rpx solid #F0F0F0; }
.youth-enrolled { font-size:24rpx; color:#999; }
.youth-note { font-size:22rpx; color:#F5A623; }
.youth-price-action { text-align:right; }
.youth-price { font-size:32rpx; font-weight:700; color:#F5A623; display:block; }
.youth-action { font-size:26rpx; color:#5B9BD5; margin-top:4rpx; display:block; }

.bottom-space { height:40rpx; }
