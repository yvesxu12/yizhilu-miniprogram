.page-login {
  min-height: 100vh;
  background: linear-gradient(180deg, #E3F2FD 0%, #F5F7FA 40%, #FFFFFF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-container {
  width: 100%;
  max-width: 600rpx;
  padding: 0 60rpx;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B9BD5, #7BB3E0);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(91,155,213,0.3);
}

.logo-text {
  font-size: 64rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.login-slogan {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
}

.agreement-section {
  margin-bottom: 40rpx;
}

.agreement-check {
  display: flex;
  align-items: flex-start;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #CCC;
  border-radius: 50%;
  margin-right: 12rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #FFF;
}

.checkbox.checked {
  background: #5B9BD5;
  border-color: #5B9BD5;
}

.agreement-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.agreement-link {
  color: #5B9BD5;
}

.login-main-btn {
  width: 100%;
  background: linear-gradient(135deg, #5B9BD5, #7BB3E0);
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 28rpx 0;
  text-align: center;
  border: none;
  margin-bottom: 24rpx;
}

.login-main-btn.disabled {
  background: #CCCCCC;
}

.wechat-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.skip-login {
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 16rpx 0;
}
