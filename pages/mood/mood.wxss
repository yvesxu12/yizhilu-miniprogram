.page-mood { padding: 24rpx; min-height: 100vh; background: #F5F7FA; padding-bottom: 120rpx; }
.mood-card { padding: 40rpx 32rpx; }
.mood-date { font-size: 30rpx; font-weight: 600; color: #333; display: block; margin-bottom: 32rpx; }
.mood-selector { display: flex; justify-content: space-between; margin-bottom: 32rpx; }
.mood-item { display: flex; flex-direction: column; align-items: center; padding: 16rpx 12rpx; border-radius: 16rpx; transition: all 0.2s; }
.mood-item.selected { background: #E3F2FD; transform: scale(1.1); }
.mood-emoji { font-size: 56rpx; margin-bottom: 8rpx; }
.mood-label { font-size: 22rpx; color: #999; }
.mood-item.selected .mood-label { color: #5B9BD5; font-weight: 600; }
.note-input-wrap { margin-bottom: 28rpx; }
.note-input { width: 100%; min-height: 120rpx; background: #F8F9FA; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; box-sizing: border-box; }
.placeholder-text { color: #CCC; }
.submit-btn { width: 100%; background: linear-gradient(135deg, #5B9BD5, #7BB3E0); color: #FFF; font-size: 30rpx; font-weight: 600; border-radius: 44rpx; padding: 22rpx 0; border: none; margin-bottom: 28rpx; }
.ai-reply { background: linear-gradient(135deg, #F0F7FF, #F5FAFF); border-radius: 12rpx; padding: 24rpx; opacity: 0; max-height: 0; overflow: hidden; transition: all 0.3s; }
.ai-reply.show { opacity: 1; max-height: 300rpx; }
.ai-reply-header { display: flex; align-items: center; margin-bottom: 12rpx; }
.ai-icon { font-size: 28rpx; margin-right: 8rpx; }
.ai-label { font-size: 24rpx; color: #5B9BD5; font-weight: 500; }
.ai-reply-text { font-size: 26rpx; color: #555; line-height: 1.6; }
.history-section { margin-top: 32rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: #333; margin-bottom: 20rpx; display: block; }
.empty-history { text-align: center; padding: 60rpx 0; color: #CCC; font-size: 26rpx; }
.history-item { background: #FFF; border-radius: 12rpx; padding: 24rpx; margin-bottom: 12rpx; display: flex; align-items: center; justify-content: space-between; }
.history-left { display: flex; align-items: center; flex: 1; }
.history-emoji { font-size: 40rpx; margin-right: 16rpx; }
.history-info { flex: 1; }
.history-date { font-size: 26rpx; color: #666; display: block; }
.history-note { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 300rpx; }
.history-label { font-size: 24rpx; color: #999; flex-shrink: 0; }
