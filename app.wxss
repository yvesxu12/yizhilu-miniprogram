/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333333;
  background-color: #F5F7FA;
}

/* 通用容器 */
.container {
  padding: 24rpx;
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #5B9BD5, #7BB3E0);
  color: #FFFFFF;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  text-align: center;
  font-size: 32rpx;
  border: none;
}

.btn-primary:active {
  opacity: 0.8;
}

/* 卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-warm {
  background: #FFF3E0;
  color: #F5A623;
}

.tag-calm {
  background: #E8F5E9;
  color: #66BB6A;
}

.tag-info {
  background: #E3F2FD;
  color: #5B9BD5;
}

/* 评分星星 */
.stars {
  color: #F5A623;
  font-size: 24rpx;
}
